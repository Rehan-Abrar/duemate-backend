# Flask Configuration
FLASK_SECRET_KEY=replace-with-a-strong-secret
FLASK_ENV=production

# JWT Authentication
JWT_SECRET=replace-with-a-strong-jwt-secret
JWT_REFRESH_SECRET=replace-with-another-strong-secret

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>

# Meta WhatsApp Cloud API
META_BEARER_TOKEN=EAAG...
META_PHONE_NUMBER_ID=123456789012345
META_BUSINESS_ACCOUNT_ID=123456789012345
META_VERIFY_TOKEN=choose-a-random-webhook-verify-token
META_APP_SECRET=your-meta-app-secret-for-signature-validation

# Groq AI API (for task parsing)
GROQ_API_KEY=gsk_...

# Web Push (VAPID keys - generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.public_key, v.private_key)")
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# Admin Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30

# Dashboard URL (for message links)
DASHBOARD_URL=https://duemate-dashboard.vercel.app/

# Message Templates
ACK_MESSAGE_TEMPLATE=DueMate: Task saved.
ACK_REVIEW_TEMPLATE=DueMate: Please review parsed details on dashboard.

# Session Configuration
SESSION_TTL_DAYS=30

# Optional explicit refresh token TTL (falls back to SESSION_TTL_DAYS)
REFRESH_TOKEN_EXPIRY_DAYS=30

# Runtime
PORT=5000

